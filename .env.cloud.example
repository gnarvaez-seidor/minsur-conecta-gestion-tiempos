# ── Testing HÍBRIDO: frontend LOCAL → backends CONECTA en CLOUD ──────────────
# Uso: cp .env.cloud.example .env.local && npm run dev -- -p 3001
#      (o exporta estas vars inline; el token se obtiene con scripts/dev-token.sh --print
#       o pegando el sToken en #/login)
#
# El rewrite dev de next.config.ts proxya /dest-apigateway/* → NEXT_PUBLIC_API_GATEWAY_URL.
NEXT_PUBLIC_AUTH_STRATEGY=seidor
NEXT_PUBLIC_API_GATEWAY_URL=https://minsur-conecta-apigateway-backend-dev.cfapps.us10-001.hana.ondemand.com
NEXT_PUBLIC_API_SEGURIDAD_URL=https://minsur-conecta-apigateway-backend-dev.cfapps.us10-001.hana.ondemand.com
NEXT_PUBLIC_APLICACION=minsur.conecta.gestion.app
# Reenvía Authorization: Bearer <sToken> en dev (se elimina del bundle en producción)
NEXT_PUBLIC_DEV_FORWARD_AUTH=true
