# ── Preset de INTEGRACIÓN LOCAL (front → gateway local → apiintegracion local) ──
# Copiar a .env.local y reiniciar `next dev` (las rewrites se leen al arrancar).
#
# 1) Levanta el stack:            (desde la raíz sap_btp)  ./dev.sh   |  ./dev.sh docker up
# 2) Obtén un token real:         (repo gateway)           npm run -s token:user:json
# 3) Pégalo en:                   http://localhost:3000/#/login
# 4) Abre la demo E2E:            http://localhost:3000/#/demo

NEXT_PUBLIC_AUTH_STRATEGY=seidor

# Ambas apuntan al gateway local (sirve /useridp y /api/*). En modo Docker,
# docker-compose sobreescribe estas URLs a http://gateway:8080 (DNS de compose).
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_API_SEGURIDAD_URL=http://localhost:8080

NEXT_PUBLIC_APLICACION=seidor.template.app

# Reenvía el sToken pegado como `Authorization: Bearer` para que el gateway
# (que valida xsuaa-central) acepte las llamadas locales. Poner en `false`
# si el token pegado NO es un JWT de xsuaa-central (p.ej. workflow QAS antiguo).
NEXT_PUBLIC_DEV_FORWARD_AUTH=true
