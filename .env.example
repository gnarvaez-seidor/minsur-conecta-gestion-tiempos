# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development:  cp .env.example .env.local
# .env.local is gitignored and OVERRIDES .env.production even in `next build`.
# ─────────────────────────────────────────────────────────────

# Auth strategy: mock | seidor | xsuaa   (see src/auth/strategies/)
#   mock   -> 100% offline, no backend/VPN/Workzone needed (DEFAULT for local dev)
#   seidor -> /useridp exchange -> sToken (the SEIDOR API Gateway model)
#   xsuaa  -> no exchange, trusts the XSUAA JWT forwarded by the approuter (CAP backends)
NEXT_PUBLIC_AUTH_STRATEGY=mock

# Backend URLs — only used by the DEV-ONLY rewrites() proxy in next.config.ts
# (in Workzone the managed approuter resolves these via destinations, so leave blank in prod).
NEXT_PUBLIC_API_GATEWAY_URL=
NEXT_PUBLIC_API_SEGURIDAD_URL=

# Sent as the `aplicacion` header by the seidor strategy (rename per app).
NEXT_PUBLIC_APLICACION=seidor.template.app

# DEV-ONLY auto-login (debug shortcut). DO NOT set here and DO NOT put it in .env.local.
# It is injected automatically by the local launchers — scripts/dev-token.sh, ../dev-conecta.sh,
# and minsurapps-setup/minsurapps.sh — as an inline/host env var holding the xsuaa-central JWT.
# When present in dev, AuthContext auto-logs-in and skips the #/login modal. Guarded by
# NODE_ENV==="development" so it is dead-code-eliminated from the production static export.
# NEXT_PUBLIC_DEV_TOKEN=   # (leave unset; the launchers fill it)
