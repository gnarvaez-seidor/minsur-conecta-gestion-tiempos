# Committed defaults applied during `next build` (the Workzone export build).
# A local .env.local (gitignored) overrides these for local inspection builds.

# Production default = the SEIDOR API Gateway model (sToken via /useridp).
# Switch to `xsuaa` here if this app fronts a CAP backend that trusts the XSUAA JWT directly.
NEXT_PUBLIC_AUTH_STRATEGY=seidor

# Header sent on composite/Path-B calls. RENAME per app.
NEXT_PUBLIC_APLICACION=minsur.conecta.gestion.app
